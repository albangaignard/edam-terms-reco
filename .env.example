DEFAULT_PROVIDER=ollama

# Global LLM options
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2
ENABLE_DYNAMIC_MODEL_LIST=true

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODELS=qwen3:14b,starcoder:latest,deepseek-coder-v2:latest,llama3:latest,codestral:latest,mistral:latest

# Groq
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODELS=openai/gpt-oss-120b,llama-3.3-70b-versatile

# Albert
ALBERT_BASE_URL=https://albert.api.etalab.gouv.fr/v1/
ALBERT_API_KEY=
ALBERT_MODELS=openai/gpt-oss-120b,Qwen/Qwen3-Coder-30B-A3B-Instruct,mistralai/Ministral-3-8B-Instruct-2512,BAAI/bge-m3,BAAI/bge-reranker-v2-m3,mistralai/Mistral-Small-3.2-24B-Instruct-2506,openai/whisper-large-v3

# Generic local OpenAI-compatible endpoint (LM Studio/vLLM/etc.)
DEV_OPENAI_BASE_URL=http://localhost:8000/v1
DEV_OPENAI_API_KEY=
DEV_OPENAI_MODELS=
