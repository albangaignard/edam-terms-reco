DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=

# Global LLM options
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# Groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Albert (OpenAI-compatible endpoint)
ALBERT_BASE_URL=https://api.albert.com/v1
ALBERT_API_KEY=
ALBERT_MODEL=albert-large

# Generic local OpenAI-compatible endpoint (LM Studio/vLLM/etc.)
DEV_OPENAI_BASE_URL=http://localhost:8000/v1
DEV_OPENAI_API_KEY=dummy-key
DEV_OPENAI_MODEL=local-model
