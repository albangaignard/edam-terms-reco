DEFAULT_PROVIDER=ollama

# Global LLM options
LLM_TEMPERATURE=0
LLM_MAX_RETRIES=2
ENABLE_DYNAMIC_MODEL_LIST=true

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODELS=qwen3:14b,llama3.1:8b

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODELS=openai/gpt-oss-120b,llama-3.3-70b-versatile

# Albert
ALBERT_BASE_URL=https://albert.api.etalab.gouv.fr/v1/
ALBERT_API_KEY=
ALBERT_MODELS=openai/gpt-oss-120b,mistralai/Mistral-Small-3.2-24B-Instruct-2506

# Generic local OpenAI-compatible endpoint (LM Studio/vLLM/etc.)
DEV_OPENAI_BASE_URL=http://localhost:8000/v1
DEV_OPENAI_API_KEY=dummy-key
DEV_OPENAI_MODELS=local-model
